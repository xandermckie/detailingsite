NODE_ENV=production
PORT=3000
DATABASE_PATH=./data/bookings.db

# Encryption key for sensitive data (keep this secret!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-character-hex-string-here

# Admin API key for /api/bookings/:id/details endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_API_KEY=your-admin-api-key-here

# CSRF token secret
CSRF_SECRET=your-csrf-secret-here

# Email settings (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Site settings
SITE_URL=https://yoursite.com
RAILWAY_API_ORIGIN=https://your-app.up.railway.app
