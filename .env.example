NODE_ENV=production
PORT=3000
DATABASE_PATH=./data/bookings.db

# Encryption key for sensitive data (keep this secret!)
# Must be 64 hex characters (32 bytes). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string-here

# Admin API key for /api/admin/* endpoints (min 16 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_API_KEY=your-admin-api-key-here

# Minutes before the same email can submit another booking (default 15)
BOOKING_EMAIL_COOLDOWN_MINUTES=15

# Email settings (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
OWNER_EMAIL=secondsfoodtruck@gmail.com

# Site settings (comma-separated for multiple origins)
SITE_URL=https://yoursite.com
ALLOWED_ORIGINS=https://yoursite.com,http://localhost:3000
RAILWAY_API_ORIGIN=https://your-app.up.railway.app
